<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Font Pairing</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app">
    <aside class="sidebar">
      <h2 class="sidebar-title">Controls</h2>
      <p class="sidebar-hint">Lock and Fetch fonts will be added by your team.</p>
    </aside>
    <main class="preview">
      <h1 class="preview-header" id="preview-header">Heading</h1>
      <h2 class="preview-subheader" id="preview-subheader">Subheading</h2>
      <p class="preview-body" id="preview-body">Body text. This is where paragraph content would appear so you can see how the font looks at a readable size.</p>
    </main>
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
