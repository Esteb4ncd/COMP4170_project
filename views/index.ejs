<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Font Pairing</title>
  <link rel="stylesheet" href="/css/style.css">
  <link id="google-fonts-link" rel="stylesheet" href="">
</head>
<body>
  <section class="landing" id="landing">
    <div class="landing-glow landing-glow-one"></div>
    <div class="landing-glow landing-glow-two"></div>
    <div class="landing-content">
      <p class="landing-kicker">Font Pairing Studio</p>
      <h1 class="landing-title">Create Beautiful Font Combinations In Seconds</h1>
      <p class="landing-subtitle">Explore playful typography pairings, preview every letter clearly, and test your own copy live.</p>
      <button type="button" class="landing-cta" id="start-generating">Start Generating</button>
    </div>
  </section>

  <div class="app app-hidden" id="generator-app" aria-hidden="true">
    <aside class="sidebar">
      <h1 class="sidebar-title">Font Pair Playground</h1>
      <p class="sidebar-hint">Generate from the database, lock fonts you like, and test with your own words.</p>

      <button type="button" class="btn-fetch" id="btn-fetch">Generate</button>
      <p class="status-message" id="status-message" aria-live="polite"></p>

      <section class="panel">
        <h2 class="panel-title">Current Fonts</h2>
        <p class="font-row">Header: <span id="font-header">-</span></p>
        <p class="font-row">Subheader: <span id="font-subheader">-</span></p>
        <p class="font-row">Body: <span id="font-body">-</span></p>
      </section>

      <section class="panel">
        <h2 class="panel-title">Lock Fonts</h2>
        <label class="slot-label">
          <input type="checkbox" class="lock" id="lock-header" aria-label="Lock header font">
          Lock header font
        </label>
        <label class="slot-label">
          <input type="checkbox" class="lock" id="lock-subheader" aria-label="Lock subheader font">
          Lock subheader font
        </label>
        <label class="slot-label">
          <input type="checkbox" class="lock" id="lock-body" aria-label="Lock body font">
          Lock body font
        </label>
      </section>

      <section class="panel">
        <h2 class="panel-title">Try Your Own Text</h2>
        <label class="input-label" for="input-header">Heading text</label>
        <input id="input-header" class="text-input" type="text" placeholder="Type your heading...">
        <label class="input-label" for="input-subheader">Subheading text</label>
        <input id="input-subheader" class="text-input" type="text" placeholder="Type your subheading...">
        <label class="input-label" for="input-body">Body text</label>
        <textarea id="input-body" class="text-input text-area" rows="4" placeholder="Type your paragraph..."></textarea>
      </section>
    </aside>

    <main class="preview-panel">
      <h1 class="preview-header" id="preview-header">Design your heading here</h1>
      <p class="sample-line" id="sample-header">The quick brown fox jumps over the lazy dog. ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789</p>

      <h2 class="preview-subheader" id="preview-subheader">Subheading preview text goes here</h2>
      <p class="sample-line" id="sample-subheader">Sphinx of black quartz, judge my vow. ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789</p>

      <p class="preview-body" id="preview-body">Use this section to test your body copy. You can type your own sentence in the left panel and it will update live so every letter and spacing detail is easy to review.</p>
      <p class="sample-line" id="sample-body">Pack my box with five dozen liquor jugs. ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789</p>
    </main>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" integrity="sha512-7eHRwcbvY1f6fM4bNw7jY5VhQXmxhXv7n5Qn2ATqNnS/xP8s3HdWu3UwG+329xNXmLKcKD5Vac/mswHx0Er8xQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script src="/js/main.js"></script>
</body>
</html>
